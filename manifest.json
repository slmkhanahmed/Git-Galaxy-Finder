{
  "manifest_version": 3,
  "version": "2.0",
  "name": "gehance",
  "description": "An extension template using React and TypeScript. This template includes a content script using Tailwind.css. To see it in action, visit https://docs.extensioncreate.com.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon/icon_16.png",
      "48": "icon/icon_48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/stars/*/lists/*",
        "https://github.com/*?tab=stars"
      ],
      "js": [
        "./content/content.tsx"
      ]
    }
  ],
  "icons": {
    "16": "icon/icon_16.png",
    "48": "icon/icon_48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{7a13b8e6-c69a-499a-9a09-c4412b5edbfb}"
    }
  }
}